# Copy these keys into Railway → Service → Variables (use References/Secrets for values).
# Do not commit real secrets.

SUPABASE_URL=
SUPABASE_KEY=
# Optional alias supported by the backend. Use the same value as SUPABASE_KEY if your host calls it anon key.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

OPENAI_API_KEY=
SARVAM_API_KEY=
CAL_API_KEY=
CAL_EVENT_TYPE_ID=

# Optional
# SENTRY_DSN=
# N8N_WEBHOOK_URL=
# PORT is set by Railway automatically.
