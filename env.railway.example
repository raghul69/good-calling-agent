# Copy these keys into Railway → Service → Variables (use References/Secrets for values).
# Do not commit real secrets.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional, useful for user-scoped Supabase auth calls. Use your anon public key.
SUPABASE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Vercel production URL, for example:
# CORS_ORIGIN=https://your-frontend.vercel.app
CORS_ORIGIN=

OPENAI_API_KEY=
SARVAM_API_KEY=
CAL_API_KEY=
CAL_EVENT_TYPE_ID=

# Optional
# SENTRY_DSN=
# N8N_WEBHOOK_URL=
# PORT is set by Railway automatically.
