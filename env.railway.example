# Copy these keys into Railway → Service → Variables (use References/Secrets for values).
# Do not commit real secrets.
#
# Supabase Auth URLs (dashboard): Authentication → URL Configuration → set Site URL +
# Redirect URLs using your Railway API host and Vercel app host — see SUPABASE_SETUP.md ("Auth URLs").

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional, useful for user-scoped Supabase auth calls. Use your anon public key.
SUPABASE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Preferred name; also sets OUTBOUND_TRUNK_ID if unset.
LIVEKIT_SIP_TRUNK_ID=
OUTBOUND_TRUNK_ID=

# Optional fleet-wide SIP transfer fallback when call_config.transfer_destination_e164 is empty.
# Prefer setting Transfer destination (E.164) on the agent Call tab in production.
DEFAULT_TRANSFER_NUMBER=

# localhost:5173 covers default Vite when not overriding server.port (this repo defaults Vite to 3000 — both are listed in backend CORS defaults).
CORS_ORIGIN=https://good-calling-agent.vercel.app,https://good-calling-agent-jettones-projects.vercel.app,https://good-calling-agent-git-main-jettones-projects.vercel.app,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# Optional: custom Vercel preview regex, or literal "disabled" to rely on CORS_ORIGIN list only (no wildcard preview regex).
# CORS_ORIGIN_REGEX=disabled
# Public frontend URL used for Stripe Checkout/Portal return URLs.
PUBLIC_APP_URL=https://good-calling-agent.vercel.app

OPENAI_API_KEY=
# Groq: orchestration packs + Tamil UNDERSTAND step (defaults to llama-3.1-8b-instant if unset)
GROQ_API_KEY=
# Optional override — same default as backend/orchestration/packs/groq_json.py resolve_groq_model()
GROQ_MODEL=llama-3.1-8b-instant

VOICE_MAX_COMPLETION_TOKENS=64
DEEPGRAM_API_KEY=
SARVAM_API_KEY=
CAL_API_KEY=
CAL_EVENT_TYPE_ID=

MAX_CALL_RETRIES=3
CALL_RETRY_DELAY_SECONDS=300
CALL_RETRY_POLL_SECONDS=60
CALL_RETRY_BATCH_SIZE=5
DISABLE_CALL_RETRY_SCHEDULER=false

BILLING_PLAN_NAME=Launch
BILLING_STATUS=trial
BILLING_BASE_PRICE_USD=49
BILLING_INCLUDED_MINUTES=250
BILLING_OVERAGE_RATE_USD=0.18
# Optional Stripe billing integration markers. Real checkout/webhooks should use these.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Optional
# SENTRY_DSN=
# N8N_WEBHOOK_URL=
# Temporarily enable only for controlled production call QA, then disable.
ENABLE_INTERNAL_TEST_CALLS=false
INTERNAL_TEST_CALL_SECRET=
# PORT is set by Railway automatically.
