# Copy these keys into Railway → Service → Variables (use References/Secrets for values).
# Do not commit real secrets.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional, useful for user-scoped Supabase auth calls. Use your anon public key.
SUPABASE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Preferred name; also sets OUTBOUND_TRUNK_ID if unset.
LIVEKIT_SIP_TRUNK_ID=
OUTBOUND_TRUNK_ID=

# Browser origins allowed to call the API (comma-separated; match backend defaults in main.py).
CORS_ORIGIN=https://good-calling-agent.vercel.app,https://good-calling-agent-jettones-projects.vercel.app,https://good-calling-agent-git-main-jettones-projects.vercel.app,http://localhost:3000

OPENAI_API_KEY=
VOICE_MAX_COMPLETION_TOKENS=64
DEEPGRAM_API_KEY=
SARVAM_API_KEY=
CAL_API_KEY=
CAL_EVENT_TYPE_ID=

MAX_CALL_RETRIES=3
CALL_RETRY_DELAY_SECONDS=300
CALL_RETRY_POLL_SECONDS=60
CALL_RETRY_BATCH_SIZE=5
DISABLE_CALL_RETRY_SCHEDULER=false

BILLING_PLAN_NAME=Launch
BILLING_STATUS=trial
BILLING_BASE_PRICE_USD=49
BILLING_INCLUDED_MINUTES=250
BILLING_OVERAGE_RATE_USD=0.18

# Optional
# SENTRY_DSN=
# N8N_WEBHOOK_URL=
# PORT is set by Railway automatically.
