# Browser-safe frontend variables. Add these in Vercel Project Settings too.
NEXT_PUBLIC_API_URL=https://good-calling-agent-production.up.railway.app
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Vite-style aliases also work:
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Do not put service-role keys, LiveKit secrets, OpenAI keys, or Railway secrets in frontend env.
